# Backend server port
PORT=3000

# Comma-separated frontend origins allowed to call the API
CORS_ORIGIN=http://localhost:3001

# PostgreSQL connection string for Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_creator_studio?schema=public

# JWT settings for authentication
JWT_SECRET=dev-only-secret-change-me
JWT_EXPIRES_IN=1d

# AI provider selection (Phase 5 foundation)
AI_PROVIDER=mock

# OpenAI provider settings (backend only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=30000
