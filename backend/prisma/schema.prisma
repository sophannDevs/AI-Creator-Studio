generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String?
  role      String    @default("USER")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Project {
  id             String      @id @default(uuid())
  userId         String
  name           String
  niche          String
  language       String
  targetAudience String
  description    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoIdeas VideoIdea[]
}

model VideoIdea {
  id        String    @id @default(uuid())
  projectId String
  title     String
  hook      String?
  status    String    @default("DRAFT")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  script      Script?
  seoMetadata SeoMetadata?
  thumbnail   Thumbnail?
}

model Script {
  id          String   @id @default(uuid())
  videoIdeaId String   @unique
  hook        String
  intro       String
  mainContent String
  conclusion  String
  cta         String
  duration    String?
  tone        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  videoIdea VideoIdea @relation(fields: [videoIdeaId], references: [id], onDelete: Cascade)
}

model SeoMetadata {
  id          String   @id @default(uuid())
  videoIdeaId String   @unique
  title       String
  description String
  tags        String[]
  hashtags    String[]
  seoScore    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  videoIdea VideoIdea @relation(fields: [videoIdeaId], references: [id], onDelete: Cascade)
}

model Thumbnail {
  id             String   @id @default(uuid())
  videoIdeaId    String   @unique
  text           String
  backgroundIdea String
  mainObject     String
  style          String
  prompt         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  videoIdea VideoIdea @relation(fields: [videoIdeaId], references: [id], onDelete: Cascade)
}
